# Example environment variables for the birthday wish card
# Copy this file to .env.local and fill in your values

# Custom messages (optional)
VITE_BIRTHDAY_PERSON_NAME=Zehra
VITE_BIRTHDAY_MESSAGE=Happy Birthday! May all your dreams come true!

# Analytics (optional)
VITE_GA_TRACKING_ID=
VITE_HOTJAR_ID=

# API endpoints (if needed for future features)
VITE_API_BASE_URL=https://api.example.com

# Feature flags (optional)
VITE_ENABLE_MUSIC=true
VITE_ENABLE_ANALYTICS=false
